[Unit]
Description=Vault Unseal Script
After=vault.service
Requires=vault.service
PartOf=vault.service

[Service]
Type=oneshot
User=vault
Group=bin
Environment="VAULT_TOKEN_HELPER="
EnvironmentFile=/etc/vault.d/vault-unseal.env
ExecStartPre=/bin/echo "Waiting 15 seconds before unsealing Vault..."
ExecStartPre=/bin/sleep 15
ExecStart=/usr/local/bin/vault-unseal.sh
RemainAfterExit=yes
StandardOutput=journal
StandardError=journal
Restart=on-failure
RestartSec=5
StartLimitBurst=5

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/etc/vault.d

[Install]
WantedBy=multi-user.target
